{
  "TSDFDataFrameWrapperTests": {
    "test_select_single_column": {
      "init": {
        "tsdf": {
          "ts_col": "timestamp",
          "series_ids": ["symbol"]
        },
        "df": {
          "schema": "symbol string, timestamp string, price float, volume int",
          "ts_convert": ["timestamp"],
          "data": [
            ["A", "2024-01-01 10:00:00", 100.0, 1000],
            ["A", "2024-01-01 11:00:00", 105.0, 1500],
            ["B", "2024-01-01 10:00:00", 200.0, 2000]
          ]
        }
      }
    },
