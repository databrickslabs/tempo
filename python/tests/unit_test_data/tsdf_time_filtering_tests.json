  "TSDFEarliestLatestTests": {
    "test_earliest_multiple_series": {
      "init": {
        "tsdf": {
          "ts_col": "timestamp",
          "series_ids": ["ticker"]
        },
        "df": {
          "schema": "ticker string, timestamp string, value float",
          "ts_convert": ["timestamp"],
          "data": [
            ["X", "2024-01-01 09:00:00", 10.0],
            ["X", "2024-01-01 10:00:00", 11.0],
            ["X", "2024-01-01 11:00:00", 12.0],
            ["X", "2024-01-01 12:00:00", 13.0],
            ["X", "2024-01-01 13:00:00", 14.0],
            ["Y", "2024-01-01 09:00:00", 20.0],
            ["Y", "2024-01-01 10:00:00", 21.0],
            ["Y", "2024-01-01 11:00:00", 22.0]
          ]
        }
      }
    },
