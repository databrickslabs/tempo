{
  "TSDFTimeFilteringTests": {
    "test_earliest": {
      "init": {
        "tsdf": {
          "ts_col": "timestamp",
          "series_ids": ["symbol"]
        },
        "df": {
          "schema": "symbol string, timestamp string, price float",
          "ts_convert": ["timestamp"],
          "data": [
            ["A", "2024-01-01 10:00:00", 100.0],
            ["A", "2024-01-01 12:00:00", 101.0],
            ["A", "2024-01-01 14:00:00", 102.0],
            ["A", "2024-01-02 10:00:00", 103.0]
          ]
        }
      }
    },
    "test_earliest_single": {
      "init": {
        "tsdf": {
          "ts_col": "timestamp",
