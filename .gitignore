# ignore IntelliJ/PyCharm/VSCode IDE files
.idea
*.iml
.vscode


# coverage files
.coverage
.coverage.*
coverage.xml

# local delta tables
**/spark-warehouse

# ignore build files
**/build
**/dist
**/htmlcov
**/tempo.egg-info
**/dbl_tempo.egg-info

## Python related files
*.pyc
**/__pycache__

# NOTE: .python-version is intentionally tracked (uv reads it to pick the
# default interpreter); do not add it to this ignore list.

## tox files
.tox
python/.tox

# ignore virtual environments
python/venv
python/.venv
python/.env
venv
.venv
.env

# developer-local Make overrides (e.g. an internal package index)
local.mk

# other misc ignore
.DS_Store
/docs/_build/

# sphinx build folder
docs/_build

# ignore mypy cache
.mypy_cache
python/.mypy_cache
.aider*

# ignore Claude Code files
.claude
